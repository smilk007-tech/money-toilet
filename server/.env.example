# 소켓서버(Railway) 환경변수 — Railway 대시보드 Variables에 등록
# (이 파일은 예시일 뿐, 실제 값은 커밋 금지. .env* 는 .gitignore 처리됨)

# Upstash Redis (Vercel과 같은 인스턴스 사용)
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxx

# 어드민 비밀번호 (긴 랜덤값)
ADMIN_SECRET=change-me-to-a-long-random-string

# 허용 오리진 (프론트 도메인) — 쉼표로 여러 개
ALLOWED_ORIGIN=https://moneytoilet.kr

# 포트 — Railway가 자동 주입하므로 보통 설정 불필요(로컬만 4000)
# PORT=4000
