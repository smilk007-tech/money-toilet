# Vercel 환경변수 예시 — Vercel 대시보드 Settings > Environment Variables에 등록
# (이 파일은 예시일 뿐, 실제 값은 커밋 금지)

# ── 필수 ──────────────────────────────────────────────────────────────────────

# 소켓 서버 URL (Railway 배포 주소)
NEXT_PUBLIC_SOCKET_URL=https://your-socket-server.railway.app

# 실시간 소켓 활성화 ("1" = 활성, 없으면 비활성/로컬 페이크소켓)
NEXT_PUBLIC_RT=1

# 프론트 도메인 (공유 링크 생성에 사용)
NEXT_PUBLIC_SITE_URL=https://moneytoilet.kr

# Upstash Redis (어드민 과거 통계 직접 조회용, 소켓서버와 같은 인스턴스)
KV_REST_API_URL=https://xxxx.upstash.io
KV_REST_API_TOKEN=xxxxxxxx

# 공지 배너는 어드민 대시보드 > 🛠 제어 탭에서 관리합니다. (Vercel 환경변수 불필요)
